# Copy to .env and edit. All vars prefixed ARTIFACTBAY_.

# Dev default = Postgres from `docker compose up -d` (see ../docker-compose.yml).
ARTIFACTBAY_DATABASE_URL=postgresql+psycopg://artifactbay:artifactbay@localhost:5432/artifactbay
# Zero-setup fallback (no Docker): ARTIFACTBAY_DATABASE_URL=sqlite:///./artifactbay.db

# Used to build absolute URLs returned to agents/clients.
ARTIFACTBAY_BASE_URL=http://localhost:8000

# Bootstrap write API key — seeded as a hashed key on startup. CHANGE THIS.
ARTIFACTBAY_API_KEY=ab_dev_changeme

# Auth — CHANGE all of these in real deploys.
ARTIFACTBAY_JWT_SECRET=dev-insecure-change-me-please-32byte-minimum
ARTIFACTBAY_ADMIN_USERNAME=admin
ARTIFACTBAY_ADMIN_PASSWORD=admin
# ARTIFACTBAY_COOKIE_SECURE=true   # enable behind HTTPS
