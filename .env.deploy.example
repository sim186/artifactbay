# Copy to .env next to docker-compose.deploy.yml, then fill in the secrets.
#   cp .env.deploy.example .env
# Generate strong secrets:
#   openssl rand -base64 48     # JWT secret + admin password
#   echo "ab_$(openssl rand -hex 24)"   # API key (the ab_ prefix is expected)

# Public origin the app is reached at — used to build share/artifact links.
# MUST match the URL users actually hit (scheme + host [+ port]).
ARTIFACTBAY_BASE_URL=https://artifacts.example.com

# Bootstrap API key handed to agents (Authorization: Bearer ab_...).
ARTIFACTBAY_API_KEY=ab_change_me_to_a_long_random_value

# Signs auth cookies. 32+ bytes of randomness. Rotating it logs everyone out.
ARTIFACTBAY_JWT_SECRET=change_me_to_a_long_random_value

# First admin login.
ARTIFACTBAY_ADMIN_USERNAME=admin
ARTIFACTBAY_ADMIN_PASSWORD=change_me

# Postgres password (internal to the compose network, but still set it).
POSTGRES_PASSWORD=change_me_too

# Optional overrides:
# ARTIFACTBAY_IMAGE_TAG=latest        # pin a release, e.g. v1.0.0
# ARTIFACTBAY_WEB_PORT=8080           # host port for the dashboard
# ARTIFACTBAY_COOKIE_SECURE=true      # set false only if serving plain http
