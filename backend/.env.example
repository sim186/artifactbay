# Copy to .env and edit. All vars prefixed FOUNDRY_.

# Dev default = Postgres from `docker compose up -d` (see ../docker-compose.yml).
FOUNDRY_DATABASE_URL=postgresql+psycopg://foundry:foundry@localhost:5432/foundry
# Zero-setup fallback (no Docker): FOUNDRY_DATABASE_URL=sqlite:///./foundry.db

# Used to build absolute URLs returned to agents/clients.
FOUNDRY_BASE_URL=http://localhost:8000

# Bootstrap write API key — seeded as a hashed key on startup. CHANGE THIS.
FOUNDRY_API_KEY=fdy_dev_changeme

# Auth — CHANGE all of these in real deploys.
FOUNDRY_JWT_SECRET=dev-insecure-change-me-please-32byte-minimum
FOUNDRY_ADMIN_USERNAME=admin
FOUNDRY_ADMIN_PASSWORD=admin
# FOUNDRY_COOKIE_SECURE=true   # enable behind HTTPS
