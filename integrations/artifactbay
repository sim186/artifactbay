#!/usr/bin/env bash
# Thin wrapper so any agent/shell can call `artifactbay push` / `artifactbay doctor`.
# Symlink onto PATH:   ln -s "$PWD/integrations/artifactbay" /usr/local/bin/artifactbay
# Then: artifactbay doctor | artifactbay push --name "..."
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec python3 "$HERE/artifactbay_cli.py" "$@"
